# API Keys
# You can use either OpenAI or Anthropic (or both)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Model Configuration
# API Provider: openai or anthropic
API_PROVIDER=openai

# OpenAI models: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-preview, o1-mini
# Anthropic models: claude-opus-4-5, claude-sonnet-4, claude-sonnet-3-5-v2
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7

# Paths
DATA_DIR=./data
EXEMPLAR_PATH=./data/exemplars.json
